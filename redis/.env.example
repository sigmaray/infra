REDIS_PASSWORD=change-me-redis-password

# Host port (bound to 127.0.0.1 only — not exposed to the public internet).
REDIS_PORT=6379

# REDIS_URL examples (see README.md):
# Docker app on infra network (database 0):
# redis://:<REDIS_PASSWORD>@redis:6379/0
# Host-native app:
# redis://:<REDIS_PASSWORD>@127.0.0.1:6379/0
