POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

# Host port (bound to 127.0.0.1 only — not exposed to the public internet).
POSTGRES_PORT=5432

# DATABASE_URL examples (see README.md):
# Docker app on infra network:
# postgresql://postgres:<POSTGRES_PASSWORD>@postgresql:5432/weather
# Host-native app:
# postgresql://postgres:<POSTGRES_PASSWORD>@127.0.0.1:5432/weather
#
# Automated dumps: see ../postgres-backup/
