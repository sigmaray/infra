POSTGRES_USER=postgres
# Must match the password in ../postgres/.env
POSTGRES_PASSWORD=change-me-postgres-password

# Target (defaults reach the shared postgres container on network infra).
PGHOST=postgresql
PGPORT=5432

# Comma-separated DB names. Empty = all non-template databases except "postgres".
# BACKUP_DATABASES=weather,bugsink

# Keep dumps for this many days (0 = never delete).
BACKUP_RETENTION_DAYS=14

# Crontab schedule (container TZ). Default: daily at 03:00.
BACKUP_CRON=0 3 * * *

# Timezone for the backup schedule.
TZ=UTC
