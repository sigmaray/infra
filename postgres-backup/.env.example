POSTGRES_USER=postgres
# Must match the password in ../postgres/.env
POSTGRES_PASSWORD=change-me-postgres-password

# Target (defaults reach the shared postgres container on network infra).
PGHOST=postgresql
PGPORT=5432

# Comma-separated DB names. Empty = all non-template databases except "postgres".
# BACKUP_DATABASES=weather,bugsink

# Destinations (independent; at least one must be true).
BACKUP_LOCAL=true
BACKUP_S3=false

# Local volume retention (only when BACKUP_LOCAL=true). 0 = never delete.
BACKUP_RETENTION_DAYS=14

# S3 (only when BACKUP_S3=true). Works with AWS S3, MinIO, R2, Yandex, etc.
# S3_BUCKET=my-pg-backups
# S3_PREFIX=postgres
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# Optional custom endpoint (MinIO / R2 / …):
# AWS_ENDPOINT_URL=https://s3.example.com

# Crontab schedule (container TZ). Default: daily at 03:00.
BACKUP_CRON=0 3 * * *

# Timezone for the backup schedule.
TZ=UTC
