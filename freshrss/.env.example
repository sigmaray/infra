# Host bind for direct access (Caddy uses freshrss:80 on the infra network).
# 127.0.0.1 — local access only (recommended when using reverse-proxy)
# 0.0.0.0   — accept connections from the internet
FRESHRSS_BIND_ADDRESS=127.0.0.1
FRESHRSS_PORT=8081

# Server timezone: https://www.php.net/manual/en/timezones.php
TZ=Europe/Moscow

# Built-in cron for feed refresh (disabled when empty).
# Examples: */5 (every 5 minutes), 3,33 (twice per hour)
CRON_MIN=*/5

# Trusted reverse-proxy CIDR ranges (Caddy, Docker networks).
TRUSTED_PROXY=172.16.0.1/12 192.168.0.1/16
