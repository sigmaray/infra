# Public IP or hostname VPN clients use to reach this server (wg-easy v15 INIT_HOST).
INIT_HOST=your-server.example.com

# Unattended first-time setup (wg-easy v15). Edit INIT_HOST before production use.
INIT_ENABLED=true
INIT_USERNAME=admin
INIT_PASSWORD=change-me-wg-easy
INIT_PORT=51820

# Required for HTTP access without HTTPS (no reverse proxy TLS).
INSECURE=true

LANG=en
# Host bind address for the web UI (0.0.0.0 for internet access)
WG_EASY_WEB_BIND_ADDRESS=127.0.0.1
WG_EASY_WEB_PORT=51821
WG_EASY_WG_PORT=51820
