# Host bind for direct access (Caddy uses beszel:8090 on the infra network).
# 127.0.0.1 — local access only (recommended when using reverse-proxy)
# 0.0.0.0   — accept connections from the internet
BESZEL_BIND_ADDRESS=127.0.0.1
BESZEL_PORT=8090

# Public URL Beszel uses for links and OAuth callbacks.
# Production: set to your Caddy hostname (e.g. https://beszel.example.com).
BESZEL_APP_URL=http://127.0.0.1:8090

# Server timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Moscow
