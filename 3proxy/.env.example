PROXY_USER=proxy
PROXY_PASSWORD=change-me-proxy-password

# Bind address for published host ports.
# 127.0.0.1 — local access only (default)
# 0.0.0.0   — accept connections from the internet (open ports in firewall)
PROXY_BIND_ADDRESS=0.0.0.0

HTTP_PROXY_PORT=3128
SOCKS_PROXY_PORT=1080

# 3proxy.cfg is generated from this file: ./scripts/generate-3proxy-cfg.sh

# Proxy URL examples (see README.md):
# Local:    http://proxy:<PROXY_PASSWORD>@127.0.0.1:3128
# Remote:   http://proxy:<PROXY_PASSWORD>@<server-ip>:3128
# SOCKS5:   socks5://proxy:<PROXY_PASSWORD>@<server-ip>:1080
