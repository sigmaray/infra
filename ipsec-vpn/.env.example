# IPsec PSK, username and password for IPsec/L2TP and Cisco IPsec modes.
# - DO NOT put "" or '' around values, or add space around =
# - DO NOT use these special characters within values: \ " '
# - Use at least 20 random characters for VPN_IPSEC_PSK
VPN_IPSEC_PSK=change-me-ipsec-psk-twenty-chars
VPN_USER=vpnuser
VPN_PASSWORD=change-me-vpn-password

# Optional: additional VPN users (space-separated, must be paired)
# VPN_ADDL_USERS=additional_username_1 additional_username_2
# VPN_ADDL_PASSWORDS=additional_password_1 additional_password_2

# Optional: FQDN for IKEv2 server address (recommended for production)
# VPN_DNS_NAME=vpn.example.com

# Optional: name for the first IKEv2 client (one word, - and _ allowed)
# VPN_CLIENT_NAME=vpnclient

# Optional: custom DNS servers for VPN clients (default: Google Public DNS)
# VPN_DNS_SRV1=1.1.1.1
# VPN_DNS_SRV2=1.0.0.1

# Optional: set when auto-detection fails (NAT, multiple public IPs)
# VPN_PUBLIC_IP=203.0.113.10

# Optional: password-protect exported IKEv2 client config files
# VPN_PROTECT_CONFIG=yes

# Host UDP ports (published on all interfaces — required for VPN clients)
IPSEC_VPN_IKE_PORT=500
IPSEC_VPN_NAT_PORT=4500
