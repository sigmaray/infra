# Public hostname for WireGuard web UI.
# Production: set to your domain (e.g. wg.example.com) and point DNS A record to the server.
WG_EASY_HOST=wg.localhost
WG_EASY_ALT_HOST=wg.infra.local
WG_EASY_WEB_PORT=51821

# Public hostname for static file web server (../static-web/).
STATIC_WEB_HOST=static.localhost
STATIC_WEB_ALT_HOST=static.infra.local

# Published proxy ports (TCP forwarded to 3proxy on the infra network).
HTTP_PROXY_PORT=3128
SOCKS_PROXY_PORT=1080

# Caddy HTTP port on the host.
CADDY_HTTP_PORT=80

# Copy and edit Caddyfile for production: cp Caddyfile.example Caddyfile

# Bind addresses for published ports.
# 0.0.0.0   — accept connections from the internet (open ports in firewall)
# 127.0.0.1 — local access only
CADDY_BIND_ADDRESS=0.0.0.0
PROXY_FORWARD_BIND_ADDRESS=0.0.0.0
