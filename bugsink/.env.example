# Host bind for direct access (Caddy uses bugsink:8000 on the infra network).
# 127.0.0.1 — local access only (recommended when using reverse-proxy)
# 0.0.0.0   — accept connections from the internet
BUGSINK_BIND_ADDRESS=127.0.0.1
BUGSINK_PORT=8000

# Django secret key (at least 50 characters). Generate with:
#   openssl rand -base64 50
BUGSINK_SECRET_KEY=change-me-generate-with-openssl-rand-base64-50

# Initial admin account (email:password). Used only on first start; remove after login works.
BUGSINK_CREATE_SUPERUSER=admin@example.org:change-me-admin-password

# Shared PostgreSQL (../postgres/). Password must match postgres/.env.
# Create the database first: cd ../postgres && ./scripts/create-database.sh bugsink
BUGSINK_DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgresql:5432/bugsink

# Public URL Bugsink uses for links and SDK DSN hints.
# Production: set to your Caddy hostname (e.g. https://bugsink.example.com).
BUGSINK_BASE_URL=http://127.0.0.1:8000

# Set to true when Bugsink is behind Caddy or another HTTPS reverse proxy.
BUGSINK_BEHIND_HTTPS_PROXY=false

# Set to true when the proxy passes the original host via X-Forwarded-Host.
BUGSINK_USE_X_FORWARDED_HOST=false

# Server timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Moscow
