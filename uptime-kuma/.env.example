# Host bind for direct access (Caddy uses uptime-kuma:3001 on the infra network).
# 127.0.0.1 — local access only (recommended when using reverse-proxy)
# 0.0.0.0   — accept connections from the internet
UPTIME_KUMA_BIND_ADDRESS=127.0.0.1
UPTIME_KUMA_PORT=8083

# Server timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Moscow

# Allow embedding the dashboard in an iframe (0 = default, same-origin only).
UPTIME_KUMA_DISABLE_FRAME_SAMEORIGIN=0
